# libssh2 - SSH2 client library
# Used by libcurl for scp/sftp support
LIB_NAME=libssh2
LIB_VERSION=1.11.0
LIB_SOURCE=build
LIB_URL="https://www.libssh2.org/download/libssh2-1.11.0.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
export CFLAGS="-fPIC -I$STATIC_PREFIX/include"
export CPPFLAGS="-I$STATIC_PREFIX/include"
export LDFLAGS="-L$STATIC_PREFIX/lib -L$STATIC_PREFIX/lib64"
export PKG_CONFIG_PATH="$STATIC_PREFIX/lib/pkgconfig:$STATIC_PREFIX/lib64/pkgconfig:/usr/lib/pkgconfig:/usr/share/pkgconfig"
./configure \
  --prefix="$STATIC_PREFIX" \
  --enable-static \
  --disable-shared \
  --with-openssl \
  --with-libssl-prefix="$STATIC_PREFIX" \
  --with-libz
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libssh2.so* "$STATIC_PREFIX/lib"/*.la 2>/dev/null || true
if [ -f "$STATIC_PREFIX/lib/pkgconfig/libssh2.pc" ]; then
  sed -i "s|^prefix=.*|prefix=$STATIC_PREFIX|g" "$STATIC_PREFIX/lib/pkgconfig/libssh2.pc"
  sed -i "s|^exec_prefix=.*|exec_prefix=\${prefix}|g" "$STATIC_PREFIX/lib/pkgconfig/libssh2.pc"
  sed -i "s|^libdir=.*|libdir=\${exec_prefix}/lib|g" "$STATIC_PREFIX/lib/pkgconfig/libssh2.pc"
  sed -i "s|^includedir=.*|includedir=\${prefix}/include|g" "$STATIC_PREFIX/lib/pkgconfig/libssh2.pc"
fi
'
