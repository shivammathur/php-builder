# hunspell - Spell checking library
# Backend for enchant
LIB_NAME=hunspell
LIB_VERSION=1.7.2
LIB_SOURCE=build
LIB_URL="https://github.com/hunspell/hunspell/releases/download/v1.7.2/hunspell-1.7.2.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
export CFLAGS="-fPIC -I$STATIC_PREFIX/include"
export CXXFLAGS="-fPIC -I$STATIC_PREFIX/include"
export LDFLAGS="-L$STATIC_PREFIX/lib"
./configure --prefix="$STATIC_PREFIX" \
  --enable-static --disable-shared
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libhunspell*.so* "$STATIC_PREFIX/lib"/*.la 2>/dev/null || true
'
