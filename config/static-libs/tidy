# tidy - HTML Tidy library
# Used for PHP tidy extension
LIB_NAME=tidy
LIB_VERSION=5.8.0
LIB_SOURCE=build
LIB_URL="https://github.com/htacg/tidy-html5/archive/refs/tags/5.8.0.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
mkdir -p build && cd build
cmake -DCMAKE_INSTALL_PREFIX="$STATIC_PREFIX" \
      -DCMAKE_BUILD_TYPE=Release \
      -DBUILD_SHARED_LIB=OFF \
      -DSUPPORT_CONSOLE_APP=OFF \
      -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
      ..
make -j"$JOBS"
make install
# Symlink if installed to lib64
if [ ! -f "$STATIC_PREFIX/lib/libtidy.a" ] && [ -f "$STATIC_PREFIX/lib64/libtidy.a" ]; then
  ln -sf "$STATIC_PREFIX/lib64/libtidy.a" "$STATIC_PREFIX/lib/libtidy.a"
fi
# Create pkgconfig
mkdir -p "$STATIC_PREFIX/lib/pkgconfig"
cat > "$STATIC_PREFIX/lib/pkgconfig/tidy.pc" << PKGEOF
prefix=$STATIC_PREFIX
exec_prefix=\${prefix}
libdir=\${exec_prefix}/lib
includedir=\${prefix}/include

Name: TidyLib
Description: HTML Tidy library
Version: 5.8.0
Libs: -L\${libdir} -ltidy
Cflags: -I\${includedir}
PKGEOF
'
