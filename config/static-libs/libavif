# libavif - AVIF image codec library
# Required for PHP gd AVIF support
LIB_NAME=libavif
LIB_VERSION=1.1.1
LIB_SOURCE=build
LIB_URL="https://github.com/AOMediaCodec/libavif/archive/refs/tags/v${LIB_VERSION}.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
mkdir -p build && cd build
cmake .. \
  -DCMAKE_INSTALL_PREFIX="$STATIC_PREFIX" \
  -DCMAKE_BUILD_TYPE=Release \
  -DBUILD_SHARED_LIBS=OFF \
  -DCMAKE_POSITION_INDEPENDENT_CODE=ON \
  -DAVIF_BUILD_APPS=OFF \
  -DAVIF_BUILD_TESTS=OFF \
  -DAVIF_BUILD_EXAMPLES=OFF \
  -DAVIF_CODEC_AOM=ON \
  -DAVIF_LOCAL_AOM=OFF \
  -DAVIF_CODEC_DAV1D=OFF \
  -DAVIF_CODEC_LIBGAV1=OFF \
  -DCMAKE_PREFIX_PATH="$STATIC_PREFIX"
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libavif.so* 2>/dev/null || true
'
