# libxslt - XSLT C library
# Required for PHP xsl extension
# Depends on: libxml2
LIB_NAME=libxslt
LIB_VERSION=1.1.42
LIB_SOURCE=build
LIB_URL="https://download.gnome.org/sources/libxslt/1.1/libxslt-1.1.42.tar.xz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
CFLAGS="-fPIC -O2 -I$STATIC_PREFIX/include -I$STATIC_PREFIX/include/libxml2" \
LDFLAGS="-L$STATIC_PREFIX/lib" \
PKG_CONFIG_PATH="$STATIC_PREFIX/lib/pkgconfig" \
./configure --prefix="$STATIC_PREFIX" \
  --enable-static \
  --disable-shared \
  --with-libxml-prefix="$STATIC_PREFIX" \
  --without-python \
  --without-crypto \
  --without-debug \
  --without-mem-debug \
  --without-debugger
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libxslt.so* "$STATIC_PREFIX/lib"/libexslt.so* 2>/dev/null || true
rm -f "$STATIC_PREFIX/lib"/libxslt.la "$STATIC_PREFIX/lib"/libexslt.la 2>/dev/null || true
'
