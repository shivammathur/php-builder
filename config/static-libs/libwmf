# libwmf - WMF delegate library for ImageMagick

LIB_SOURCE="build"
LIB_NAME="libwmf"
LIB_VERSION="0.2.13"
LIB_URL="https://deb.debian.org/debian/pool/main/libw/libwmf/libwmf_${LIB_VERSION}.orig.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
set -e

export CFLAGS="-fPIC -O2 -I$STATIC_PREFIX/include"
export CXXFLAGS="-fPIC -O2 -I$STATIC_PREFIX/include"
png_static="$STATIC_PREFIX/lib/libpng16.a"
[ -f "$png_static" ] || png_static="$STATIC_PREFIX/lib/libpng.a"
if [ -f "$STATIC_PREFIX/lib/libpng16.a" ] && [ ! -e "$STATIC_PREFIX/lib/libpng.a" ]; then
  ln -sf libpng16.a "$STATIC_PREFIX/lib/libpng.a"
fi
export CPPFLAGS="-I$STATIC_PREFIX/include -I$STATIC_PREFIX/include/freetype2"
export LDFLAGS="-L$STATIC_PREFIX/lib"
export PKG_CONFIG_PATH="$STATIC_PREFIX/lib/pkgconfig"
export LIBS="$STATIC_PREFIX/lib/libfreetype.a $png_static $STATIC_PREFIX/lib/libz.a $STATIC_PREFIX/lib/libbz2.a -lm"

./configure \
  --prefix="$STATIC_PREFIX" \
  --enable-static \
  --disable-shared \
  --without-x \
  --with-freetype="$STATIC_PREFIX"

make -j"$JOBS"
make install

rm -f "$STATIC_PREFIX/lib"/libwmf.so* "$STATIC_PREFIX/lib"/libwmflite.so* \
      "$STATIC_PREFIX/lib"/libwmf.la "$STATIC_PREFIX/lib"/libwmflite.la 2>/dev/null || true

if [ -f "$STATIC_PREFIX/lib/libwmflite-0.2.a" ] && [ ! -e "$STATIC_PREFIX/lib/libwmflite.a" ]; then
  ln -sf libwmflite-0.2.a "$STATIC_PREFIX/lib/libwmflite.a"
fi

echo "libwmf ${LIB_VERSION} built successfully"
'
