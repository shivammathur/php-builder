# zlib - Compression library
# Required for many PHP extensions
LIB_NAME=zlib
LIB_VERSION=1.3.1
LIB_SOURCE=build
LIB_URL="https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
CFLAGS="-fPIC -O2" ./configure --prefix="$STATIC_PREFIX" --static
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libz.so* 2>/dev/null || true
'
