# libsodium - Modern cryptography library
# Required for PHP sodium extension
LIB_NAME=libsodium
LIB_VERSION=1.0.20
LIB_SOURCE=build
LIB_URL="https://download.libsodium.org/libsodium/releases/libsodium-1.0.20.tar.gz"
LIB_BUILD_CMD='
cd "$SRC_DIR"
CFLAGS="-fPIC -O2" \
./configure --prefix="$STATIC_PREFIX" \
  --enable-static \
  --disable-shared \
  --disable-pie
make -j"$JOBS"
make install
rm -f "$STATIC_PREFIX/lib"/libsodium.so* "$STATIC_PREFIX/lib"/libsodium.la 2>/dev/null || true
'
