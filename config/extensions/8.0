pecl msgpack
pecl pcov
pecl redis --enable-redis --enable-redis-igbinary --enable-redis-lz4 --enable-redis-lzf --enable-redis-msgpack --enable-redis-zstd --with-liblz4=/usr --with-libzstd=/usr
pecl sqlsrv-5.11.1
pecl pdo_sqlsrv-5.11.1
pecl yaml
