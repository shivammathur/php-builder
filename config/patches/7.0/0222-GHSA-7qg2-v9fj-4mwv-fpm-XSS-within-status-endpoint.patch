+    public function expectNoFile(string $extension, $prefix = null)
+    {
+        $filePath = $this->getPrefixedFile($extension, $prefix);
+        if (file_exists($filePath)) {
+            return $this->error("The file $filePath exists");
+        }
+
+        return true;
+    }
