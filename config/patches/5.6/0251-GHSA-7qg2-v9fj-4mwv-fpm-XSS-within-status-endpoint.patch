 NEWS                                               |  4 ++
 sapi/fpm/fpm/fpm_status.c                          | 20 +++++--
 sapi/fpm/tests/ghsa-7qg2-v9fj-4mwv-status-xss.phpt | 62 ++++++++++++++++++++++
 3 files changed, 82 insertions(+), 4 deletions(-)
 create mode 100644 sapi/fpm/tests/ghsa-7qg2-v9fj-4mwv-status-xss.phpt

